# Discord bot token (Developer Portal → Bot → Token)
TOKEN=tu_token_aqui

# Bot client ID (Developer Portal → OAuth2 → General → Client ID)
CLIENT_ID=tu_client_id_aqui

# Server ID para registrar comandos slash (Developer Mode → copiar ID del servidor)
GUILD_ID=tu_guild_id_aqui

# Unsplash API (unsplash.com/developers → Access Key)
UNSPLASH_ACCESS_KEY=tu_unsplash_access_key_aqui

# Groq API (console.groq.com/keys → Create API Key)
GROQ_API_KEY=tu_groq_api_key_aqui
